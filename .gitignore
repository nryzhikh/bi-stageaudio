.DS_Store
# Ignore every .env / .env.* anywhere in the tree. Committing secrets is a
# rotation emergency; a broad ignore rule is the cheapest prevention.
.env
.env.*
!.env.example
!*.env.example
!env.example
!env.*.example
venv/
venv
**/__pycache__/
**/*.pyc
.envrc

# Runtime state and generated reports
var/runtime/*
var/artifacts/*
!var/README.md
!var/artifacts/
!var/artifacts/reports/
!var/runtime/
*.log

# Large local artifacts / backups
deploy/backups/
trash/

# Ansible Galaxy collections are installed from requirements.yml, not vendored.
apps/api/ansible/collections/ansible_collections/

