# HireTrack Sync Infrastructure — Local Mac environment
# Copy to .env when running the compose stack locally.

# -- Compose project ---------------------------------------------------------
# Keep this stable so Ofelia only targets this compose project.
COMPOSE_PROJECT_NAME=hiretrack

# Enable optional services by profile. Leave empty to disable Caddy locally,
# or set to `proxy` to include it in `docker compose up -d`.
COMPOSE_PROFILES=

# Absolute host path to this deploy directory. Used by the scheduler-runner
# container when it shells out to `docker compose`.
DEPLOY_WORKDIR=/Users/nikitaryzhikh/repos/Python-Daybook/deploy

# -- MySQL (shared by the sync worker + any analytics consumers) -------------
MYSQL_ROOT_PASSWORD=rootpass123
MYSQL_DATABASE=hiretrack
MYSQL_USER=hiretrack
MYSQL_PASSWORD=hiretrack123

# -- HireTrack Flask API on the Windows host ---------------------------------
# Must be reachable from your Mac or from Docker Desktop's Linux VM.
API_URL=http://100.100.139.110:5003
API_USERNAME=
API_PASSWORD=

# -- Sync worker image -------------------------------------------------------
SYNC_CLIENT_IMAGE=ghcr.io/nryzhikh/python-daybook-sync-client:latest
# Only set this on arm64 Macs running an amd64-only image under emulation.
# Leave unset on native Linux/amd64 hosts.
SYNC_WORKER_PLATFORM=linux/amd64

# -- Superset ---------------------------------------------------------------
SUPERSET_SECRET_KEY=your-secret-key-change-me-in-production

# -- Container runtime ------------------------------------------------------
TZ=UTC
