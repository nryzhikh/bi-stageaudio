# HireTrack Sync Infrastructure — Production VPS environment
# Copy to .env on the VPS and adjust the secrets.

# -- Compose project ---------------------------------------------------------
# Keep this stable so Ofelia only targets this compose project.
COMPOSE_PROJECT_NAME=hiretrack

# Enable optional services by profile. Set to `proxy` to include Caddy in the
# normal `docker compose up -d` flow.
COMPOSE_PROFILES=

# Absolute host path to the deployed compose directory on the VPS.
DEPLOY_WORKDIR=/opt/hiretrack-sync/deploy

# -- MySQL (shared by the sync worker + any analytics consumers) -------------
MYSQL_ROOT_PASSWORD=rootpass123
MYSQL_DATABASE=hiretrack
MYSQL_USER=hiretrack
MYSQL_PASSWORD=hiretrack123

# -- HireTrack Flask API on the Windows host ---------------------------------
API_URL=http://100.100.139.110:5003
API_USERNAME=
API_PASSWORD=

# -- Sync worker image -------------------------------------------------------
SYNC_CLIENT_IMAGE=ghcr.io/nryzhikh/python-daybook-sync-client:latest

# -- Superset ---------------------------------------------------------------
SUPERSET_SECRET_KEY=your-secret-key-change-me-in-production

# -- Container runtime ------------------------------------------------------
TZ=UTC
