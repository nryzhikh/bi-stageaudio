# HireTrack Sync Infrastructure — Environment Variables
# Copy to .env and adjust. .env is gitignored; env.example is the source of truth
# for which variables exist.

# -- MySQL (shared by the sync client + any analytics consumers) -------------
# The sync-client authenticates as MYSQL_USER; root is only used by init
# scripts mounted into /docker-entrypoint-initdb.d.
MYSQL_ROOT_PASSWORD=rootpass123
MYSQL_DATABASE=hiretrack
MYSQL_USER=hiretrack
MYSQL_PASSWORD=hiretrack123

# -- HireTrack Flask API on the Windows host ---------------------------------
# Must be reachable from the VPS. If you're going over Tailscale, put the
# tailnet IP here; if over the public internet, ensure the Windows firewall
# rule for port 5003 is scoped to your VPS egress IP only.
API_URL=http://100.100.139.110:5003
# Leave blank if the API has auth disabled. With auth on, use the same
# credentials configured on the Windows side.
API_USERNAME=
API_PASSWORD=

# -- Sync worker image -------------------------------------------------------
# Build and publish this image separately, then deploy by tag.
SYNC_CLIENT_IMAGE=ghcr.io/shparenkov/python-daybook-sync-client:latest

# -- Superset ---------------------------------------------------------------
SUPERSET_SECRET_KEY=your-secret-key-change-me-in-production

# -- PostgreSQL (commented-out optional service) -----------------------------
# POSTGRES_DB=hiretrack
# POSTGRES_USER=hiretrack
# POSTGRES_PASSWORD=hiretrack123

# -- Container runtime ------------------------------------------------------
# Passed into one-shot sync containers launched by systemd timers. UTC keeps
# logs unambiguous across daylight-saving boundaries.
TZ=UTC
